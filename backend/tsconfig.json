{
    "compilerOptions": {
      "module": "commonjs",
      "target": "es2017",
      "lib": ["es2020", "dom"],
      "moduleResolution": "node",
      "sourceMap": true,
      "outDir": "./dist",
      "rootDir": "./src",
      "strict": true,
      "esModuleInterop": true,
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "noImplicitAny": false,
    },
    "include": ["src/**/*", "src/app.service.ts"],
    "outDir": "./dist",
    "rootDir": "./src"
  }
  